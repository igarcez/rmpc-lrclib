// Excerpt — merge these keys into your existing ~/.config/rmpc/config.ron.
// This is NOT a standalone config; it shows only the pieces the lyrics hook needs.
// rmpc config reference: https://mierak.github.io/rmpc/

#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]

(
    // 1. Where rmpc reads/writes .lrc files. Set this to your MPD music_directory
    //    so each .lrc lands beside its audio file (LRCLIB filename mirrors the audio).
    lyrics_dir: "~/Music/",

    // 2. Run the on-song-change dispatcher on every song change. It backgrounds every
    //    *.sh in scripts/hooks/on-song-change.d/ (lyrics fetch + notifications), so a slow
    //    LRCLIB round-trip (5-10s) never blocks rmpc. The outer `&` backgrounds the
    //    dispatcher itself. Adjust the path to where you installed it (see README).
    on_song_change: Some(["sh", "-c", "sh \"$HOME/.config/rmpc/scripts/hooks/on-song-change\" &"]),

    // 3. REQUIRED for lyrics: also fire the hook once for the track already playing
    //    when rmpc starts / a playlist loads / the config hot-reloads. Without this the
    //    current song never gets auto-fetched (rmpc default is false).
    exec_on_song_change_at_start: true,

    // 4. Add a Lyrics pane to a tab so synced lyrics render. Layout is a RON tree;
    //    match the nesting/size style of your own tabs. Minimal example:
    tabs: [
        (
            name: "Queue",
            pane: Split(
                direction: Horizontal,
                panes: [
                    (size: "40%", pane: Pane(Lyrics)),
                    (size: "60%", pane: Pane(Queue)),
                ],
            ),
        ),
    ],
)
